{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heaxhub.local/contracts/hwax-agent/manifest.schema.json",
  "title": "HWAXAgentManifest",
  "description": "Program catalog delivered to the HWAXAgent (Windows launcher) describing every installable Windows GUI module. The agent renders this list as its tile grid and uses package/entry/lifecycle to install and launch each program. Generated by backend/app/services/agent_manifest_builder.py from the union of App rows where app_type=windows_gui and an associated InstallerPackage (os=windows-x64).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "programs"],
  "properties": {
    "schema_version": {
      "const": 1,
      "description": "Manifest schema version. Bumped only on breaking changes."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Server time at which this manifest snapshot was produced. The agent caches the manifest keyed by this value."
    },
    "programs": {
      "type": "array",
      "items": { "$ref": "#/$defs/Program" }
    }
  },
  "$defs": {
    "Program": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "package", "entry"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9][a-z0-9_-]*$",
          "description": "Stable App slug — matches App.id (PK) in HEAXHub. The agent uses this as the install directory name and the registry key suffix."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Human-readable display name shown in the agent tile grid."
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$",
          "description": "SemVer of the currently published Windows installer for this program."
        },
        "description": { "type": "string", "maxLength": 1024 },
        "category": { "type": "string", "maxLength": 64 },
        "released_at": { "type": "string", "format": "date-time" },
        "package": { "$ref": "#/$defs/Package" },
        "entry": { "$ref": "#/$defs/Entry" },
        "requirements": { "$ref": "#/$defs/Requirements" },
        "lifecycle": { "$ref": "#/$defs/Lifecycle" },
        "ui": { "$ref": "#/$defs/UiHints" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "maxLength": 32 },
          "uniqueItems": true
        },
        "visibility": {
          "type": "string",
          "enum": ["private", "team", "department", "company"]
        }
      }
    },
    "Package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "url", "sha256"],
      "properties": {
        "type": { "type": "string", "enum": ["zip", "exe", "msi", "msix"] },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Absolute URL the agent will GET to fetch the installer payload. In Phase 1 this is the HEAXHub 302-redirect endpoint GET /api/v1/installers/{id}/download which itself points at a presigned object-storage URL."
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Lowercase hex SHA-256 of the installer bytes. The agent MUST verify before executing."
        },
        "size_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "Entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executable"],
      "properties": {
        "executable": {
          "type": "string",
          "description": "Relative path inside the installed program root, e.g. 'bin/HwaxDemo.exe'."
        },
        "args_template": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Argument tokens. Tokens like {workspace} / {user_id} are substituted at launch time by the agent."
        },
        "working_dir": { "type": "string" }
      }
    },
    "Requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requires_admin": { "type": "boolean", "default": false },
        "min_windows": {
          "type": "string",
          "description": "Minimum Windows build, e.g. '10.0.19045' or '11.0.22000'."
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Other program ids that must be installed first."
          },
          "uniqueItems": true
        }
      }
    },
    "Lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "post_install_check": {
          "type": "object",
          "additionalProperties": false,
          "required": ["executable"],
          "properties": {
            "executable": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" } },
            "expected_stdout_regex": { "type": "string" }
          }
        },
        "rollback_on_failure": { "type": "boolean", "default": true }
      }
    },
    "UiHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "icon_url": { "type": "string", "format": "uri" },
        "color_accent": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "show_in_tray": { "type": "boolean", "default": false }
      }
    }
  }
}
